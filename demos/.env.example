# A2UI Demos 환경 설정 - 이 파일을 .env 로 복사 후 값을 채우세요.
# 모든 데모 스크립트가 이 파일을 읽습니다.
#
# 최소 필수: OPENAI_API_KEY (또는 사내 proxy 사용 시 아래 "사내 AI proxy" 섹션 참고)

# ══════════════════════════════════════════════════════════════════
# [A] 공개 OpenAI API 사용 (https://platform.openai.com/api-keys)
# ══════════════════════════════════════════════════════════════════
OPENAI_API_KEY=your_openai_api_key_here

# 사용할 GPT 모델 (LITELLM_MODEL=openai/<GPT_MODEL> 으로 자동 변환됨)
# 예: gpt-4.1, gpt-4o, gpt-4o-mini
GPT_MODEL=gpt-4o

# ══════════════════════════════════════════════════════════════════
# [B] 사내 AI proxy / OpenAI 호환 엔드포인트 사용 (권장)
#
# 회사 LLM gateway 가 OpenAI 호환 API 를 제공하는 경우 아래 세 값만 설정.
# LiteLLM 이 OPENAI_API_BASE 를 읽어 모든 openai/* 요청을 proxy 로 보냅니다.
#
# 예시:
#   OPENAI_API_KEY=<회사에서 발급한 키>
#   OPENAI_API_BASE=https://your-company-ai-gateway.example.com/v1
#   LITELLM_MODEL=openai/gpt-4.1
# ══════════════════════════════════════════════════════════════════
# OPENAI_API_KEY=<회사 발급 키>
# OPENAI_API_BASE=https://your-company-ai-gateway.example.com/v1
# LITELLM_MODEL=openai/gpt-4.1

# ══════════════════════════════════════════════════════════════════
# [C] Gemini API 사용 (Contact / Rizzcharts / Orchestrator)
# ══════════════════════════════════════════════════════════════════
# GEMINI_API_KEY=your_gemini_api_key_here
# GEMINI_MODEL=gemini-2.5-flash

# ══════════════════════════════════════════════════════════════════
# [고급] LITELLM_MODEL 직접 지정
# 이 값이 있으면 GPT_MODEL / GEMINI_MODEL 자동 변환보다 우선합니다.
# 형식: openai/<모델명>  또는  gemini/<모델명>
# ══════════════════════════════════════════════════════════════════
# LITELLM_MODEL=openai/gpt-4.1

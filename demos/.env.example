# A2UI Demos - copy to .env and fill in your keys.
# Used by all demo scripts; model is mapped to LiteLLM format automatically.

# --- API Keys (set the ones you need for each demo) ---
# For Restaurant Finder (OpenAI):
OPENAI_API_KEY=your_openai_api_key_here

# For Contact / Rizzcharts / Orchestrator (Gemini):
# GEMINI_API_KEY=your_gemini_api_key_here

# --- Model (optional; maps to LITELLM_MODEL for agents) ---
# OpenAI: set GPT_MODEL and we use LITELLM_MODEL=openai/<GPT_MODEL>
# Example: gpt-5.4, gpt-4o, gpt-4o-mini
GPT_MODEL=gpt-5.4

# Gemini: set GEMINI_MODEL and we use LITELLM_MODEL=gemini/<GEMINI_MODEL>
# Example: gemini-2.5-flash, gemini-2.0-flash
# GEMINI_MODEL=gemini-2.5-flash

# Override: set LITELLM_MODEL directly (e.g. openai/gpt-5.4 or gemini/gemini-2.5-flash)
# LITELLM_MODEL=openai/gpt-5.4
